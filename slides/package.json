{
  "name": "neuralspeech-soutenance-1",
  "version": "1.0.0",
  "private": true,
  "description": "Slidev deck — NeuralSpeech soutenance 1",
  "scripts": {
    "dev": "slidev slides.md --open",
    "build": "slidev build slides.md",
    "export": "slidev export slides.md --output soutenance-1.pdf",
    "export-pptx": "slidev export slides.md --format pptx --output soutenance-1.pptx",
    "export-png": "slidev export slides.md --format png"
  },
  "dependencies": {
    "@slidev/cli": "^0.49.0",
    "@slidev/theme-default": "^0.25.0"
  },
  "devDependencies": {
    "playwright-chromium": "^1.45.0"
  }
}
